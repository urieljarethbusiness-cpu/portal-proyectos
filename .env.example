# ─────────────────────────────────────────────────────────────────────────────
# Portal de Proyectos — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL (OBLIGATORIA)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/portal_proyectos"

# (Opcional) Variables para integración futura con la API de Coolify
COOLIFY_API_URL=
COOLIFY_API_TOKEN=
